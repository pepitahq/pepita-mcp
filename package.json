{
  "name": "@pepitahq/mcp",
  "version": "0.1.0",
  "description": "pepita local MCP server (stdio) — drive your pepita sites from Claude.",
  "license": "MIT",
  "author": "Zoltan Gobolos <zgobolos@barelynotable.com>",
  "type": "module",
  "bin": {
    "pepita-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pepitahq/pepita-mcp.git"
  },
  "homepage": "https://github.com/pepitahq/pepita-mcp#readme",
  "bugs": {
    "url": "https://github.com/pepitahq/pepita-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@pepitahq/mcp-core": "workspace:*",
    "@pepitahq/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
